# EditorConfig — https://editorconfig.org
# Spójność dla edytorów bez Prettier-plugin (Neovim, Sublime, niektóre JetBrains setupy).
root = true

[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.md]
# Markdown — zachowaj trailing spaces (line break w GFM = "  \n").
trim_trailing_whitespace = false
max_line_length = off

[*.{yml,yaml}]
indent_size = 2

[Makefile]
indent_style = tab
